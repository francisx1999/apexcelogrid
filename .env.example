# Copy to .env and fill in. NEVER commit the real .env.
# Used by Hardhat (deploy) and the submit/ CLI.

# Signing key for deployment / registration / submission.
# Use a dedicated key that holds only a little CELO for gas.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# RPC endpoints (defaults point to Celo's public Forno nodes).
ALFAJORES_RPC_URL=https://alfajores-forno.celo-testnet.org
CELO_RPC_URL=https://forno.celo.org

# For the submit/ CLI:
RPC_URL=https://alfajores-forno.celo-testnet.org
CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT

# Optional: hand ownership to a governance address at deploy time.
# OWNER_ADDRESS=0x...

# Optional: verify the contract on Celoscan.
# CELOSCAN_API_KEY=...
